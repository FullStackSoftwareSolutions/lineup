# Copy to `.env` and fill in. `.env` is gitignored.
# Schema lives in src/env.js — keep these in sync when you add a var.
#
# Note: DB_* / DATABASE_URL live in the repo-root /.env (loaded via
# next.config.js → @next/env). Do not duplicate them here.

# --- GitHub OAuth (Lucia + Arctic) ---
# Create an app at https://github.com/settings/developers
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/auth/login/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http/api/auth/login/github/callback

# --- Dev conveniences ---
# DEV_USERNAME bypasses auth and treats every request as this user
# (see src/auth.ts getUserFromLuciaUserId). Leave blank in normal dev.
DEV_USERNAME=
# Username treated as admin in the UI
ADMIN_USERNAME=
