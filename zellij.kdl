layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="next" focus=true {
        pane command="C:/Program Files/Git/bin/bash.exe" {
            args "-lic" "cd /c/Users/joshm/Development/lineup/next && npm run dev; exec bash"
        }
    }
    tab name="whatsapp" {
        pane command="C:/Program Files/Git/bin/bash.exe" {
            args "-lic" "cd /c/Users/joshm/Development/lineup/whatsapp && npm start; exec bash"
        }
    }
    tab name="commands" {
        pane command="C:/Program Files/Git/bin/bash.exe" {
            args "-lic" "cd /c/Users/joshm/Development/lineup && exec bash"
        }
    }
    tab name="claude" {
        pane command="C:/Program Files/Git/bin/bash.exe" {
            args "-lic" "cd /c/Users/joshm/Development/lineup && claude; exec bash"
        }
    }
}
